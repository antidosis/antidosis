generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  email         String   @unique
  fullName      String?  @map("full_name")
  bio           String?
  avatarUrl     String?  @map("avatar_url")
  locationName  String?  @map("location_name")
  latitude      Float?
  longitude      Float?
  publicPhone   String?  @map("public_phone")
  privatePhone  String?  @map("private_phone")
  mobile        String?  @unique
  mobileVerified Boolean @default(false) @map("mobile_verified")
  isVerified    Boolean  @default(false) @map("is_verified")
  isPro         Boolean  @default(false) @map("is_pro")
  proActivatedAt DateTime? @map("pro_activated_at")
  proSource     String?   @map("pro_source")
  proExpiresAt  DateTime? @map("pro_expires_at")
  showInDirectory Boolean @default(false) @map("show_in_directory")
  stripeCustomerId      String? @map("stripe_customer_id")
  stripeSubscriptionId  String? @map("stripe_subscription_id")
  ratingAvg     Float    @default(0) @map("rating_avg")
  ratingCount   Int      @default(0) @map("rating_count")
  jobsCompleted Int      @default(0) @map("jobs_completed")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  skills          Skill[]
  socialLinks     SocialLink[]
  credentials     Credential[]
  needsPosted     Need[]       @relation("NeedPoster")
  acceptances     Acceptance[]
  contractsAsA    Contract[]   @relation("ContractPartyA")
  contractsAsB    Contract[]   @relation("ContractPartyB")
  reviewsGiven    Review[]     @relation("ReviewGiver")
  reviewsReceived Review[]     @relation("ReviewReceiver")
  messages        Message[]
  needMessages    NeedMessage[]
  notifications   Notification[]

  @@map("profiles")
}

model SocialLink {
  id        String  @id @default(uuid())
  profileId String  @map("profile_id")
  platform  String
  url       String
  isPublic  Boolean @default(true) @map("is_public")
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("social_links")
}

model Skill {
  id         String  @id @default(uuid())
  profileId  String  @map("profile_id")
  name       String
  category   String?
  isVerified Boolean @default(false) @map("is_verified")
  proofUrl   String? @map("proof_url")
  profile    Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("skills")
}

model Need {
  id               String   @id @default(uuid())
  posterId         String   @map("poster_id")
  title            String
  description      String
  needCategory     String?  @map("need_category")
  offerType        String   @map("offer_type")
  offerDescription String   @map("offer_description")
  offerValue       Float?   @map("offer_value")
  isLocal          Boolean  @default(true) @map("is_local")
  locationName     String?  @map("location_name")
  latitude         Float?
  longitude        Float?
  status           String   @default("open")
  deadline         DateTime?
  timeRange        String?  @map("time_range")
  images           String[]
  offerImages      String[] @map("offer_images")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  poster         Profile      @relation("NeedPoster", fields: [posterId], references: [id], onDelete: Cascade)
  requiredSkills NeedSkill[]
  acceptances    Acceptance[]
  contract       Contract?
  messages       NeedMessage[]

  @@map("needs")
}

model NeedSkill {
  id     String @id @default(uuid())
  needId String @map("need_id")
  name   String
  need   Need   @relation(fields: [needId], references: [id], onDelete: Cascade)

  @@map("need_skills")
}

model Acceptance {
  id        String   @id @default(uuid())
  needId    String   @map("need_id")
  userId    String   @map("user_id")
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  need Need    @relation(fields: [needId], references: [id], onDelete: Cascade)
  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("acceptances")
  @@index([needId])
  @@index([userId])
}

model Contract {
  id              String    @id @default(uuid())
  needId          String    @unique @map("need_id")
  partyAId        String    @map("party_a_id")
  partyBId        String    @map("party_b_id")
  terms           String
  partyATerms             String?   @map("party_a_terms")
  partyBTerms             String?   @map("party_b_terms")
  deadlineTerms           String?   @map("deadline_terms")
  completionMethodTerms   String?   @map("completion_method_terms")
  additionalTerms         String?   @map("additional_terms")
  partyAUseMessageTerms   Boolean   @default(false) @map("party_a_use_message_terms")
  partyBUseMessageTerms   Boolean   @default(false) @map("party_b_use_message_terms")
  negotiationMessages Json? @map("negotiation_messages")
  pdfUrl          String?   @map("pdf_url")
  partyAAgreedAt  DateTime? @map("party_a_agreed_at")
  partyBAgreedAt  DateTime? @map("party_b_agreed_at")
  termsLockedAt   DateTime? @map("terms_locked_at")
  partyASignedAt  DateTime? @map("party_a_signed_at")
  partyBSignedAt  DateTime? @map("party_b_signed_at")
  status          String    @default("draft")
  aMarkedComplete Boolean   @default(false) @map("a_marked_complete")
  bMarkedComplete Boolean   @default(false) @map("b_marked_complete")
  completedAt     DateTime? @map("completed_at")
  cancelledAt           DateTime? @map("cancelled_at")
  cancelledById         String?   @map("cancelled_by_id")
  cancelReason          String?   @map("cancel_reason")
  lastSignReminderSentAt DateTime? @map("last_sign_reminder_sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  need     Need      @relation(fields: [needId], references: [id], onDelete: Cascade)
  partyA   Profile   @relation("ContractPartyA", fields: [partyAId], references: [id], onDelete: Cascade)
  partyB   Profile   @relation("ContractPartyB", fields: [partyBId], references: [id], onDelete: Cascade)
  messages Message[]
  reviews  Review[]

  @@map("contracts")
  @@index([needId])
  @@index([partyAId])
  @@index([partyBId])
  @@index([status])
}

model NeedMessage {
  id        String   @id @default(uuid())
  needId    String   @map("need_id")
  senderId  String   @map("sender_id")
  content   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  need   Need    @relation(fields: [needId], references: [id], onDelete: Cascade)
  sender Profile @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("need_messages")
  @@index([needId])
  @@index([senderId])
}

model Message {
  id         String    @id @default(uuid())
  contractId String?   @map("contract_id")
  senderId   String    @map("sender_id")
  content    String
  createdAt  DateTime  @default(now()) @map("created_at")
  isRead     Boolean   @default(false) @map("is_read")

  contract Contract? @relation(fields: [contractId], references: [id], onDelete: Cascade)
  sender   Profile   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
  @@index([contractId])
  @@index([senderId])
}

model Review {
  id         String   @id @default(uuid())
  contractId String   @map("contract_id")
  giverId    String   @map("giver_id")
  receiverId String   @map("receiver_id")
  rating          Int
  comment         String?
  privateFeedback String?  @map("private_feedback")
  createdAt       DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  giver    Profile  @relation("ReviewGiver", fields: [giverId], references: [id], onDelete: Cascade)
  receiver Profile  @relation("ReviewReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([contractId, giverId])
  @@map("reviews")
}

model Credential {
  id             String    @id @default(uuid())
  profileId      String    @map("profile_id")
  type           String
  title          String
  description    String?
  documentNumber String?   @map("document_number")
  issuedBy       String?   @map("issued_by")
  issuedAt       DateTime? @map("issued_at")
  expiresAt      DateTime? @map("expires_at")
  fileUrl        String?   @map("file_url")
  isPublic       Boolean   @default(false) @map("is_public")
  isVerified     Boolean   @default(false) @map("is_verified")
  rejectionReason String?  @map("rejection_reason")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("credentials")
  @@index([profileId])
  @@index([type])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model MobileVerificationCode {
  id        String   @id @default(uuid())
  mobile    String
  code      String
  profileId String   @map("profile_id")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([mobile])
  @@index([profileId])
  @@map("mobile_verification_codes")
}

model AuditLog {
  id        String   @id @default(uuid())
  event     String
  userId    String?  @map("user_id")
  email     String?
  ip        String?
  userAgent String?  @map("user_agent")
  path      String?
  metadata  Json?
  severity  String   @default("info")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([event])
  @@index([severity])
  @@index([createdAt])
  @@map("audit_logs")
}
