# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Email
RESEND_API_KEY=re_...

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+614xxxxxxxx

# Google Play Billing
GOOGLE_PLAY_PACKAGE_NAME=com.antidosis.app
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json

# Google Play RTDN (Pub/Sub push) verification — required for the webhook
# to accept messages; it fails closed (401) when unset
PLAY_RTDN_PUSH_AUDIENCE=https://your-domain.com/api/v1/billing/play-store/webhook
PLAY_RTDN_SERVICE_ACCOUNT_EMAIL=your-pubsub-push-sa@your-project.iam.gserviceaccount.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
